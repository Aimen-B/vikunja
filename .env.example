# Local Docker Compose project name
COMPOSE_PROJECT_NAME=vikunja-source

# Local host port
VIKUNJA_APP_PORT=3456
VIKUNJA_FRONTEND_PORT=4173

# Build metadata
VIKUNJA_RELEASE_VERSION=local

# Production-like public URL and bind address
VIKUNJA_SERVICE_PUBLICURL=http://localhost:3456
VIKUNJA_SERVICE_INTERFACE=:3456
VIKUNJA_SERVICE_ROOTPATH=/app/vikunja
VIKUNJA_SERVICE_TIMEZONE=UTC

# Local hot-reload frontend URL
VIKUNJA_DEV_PUBLICURL=http://localhost:4173

# Core Vikunja settings
VIKUNJA_SERVICE_SECRET=change-me-to-a-long-random-secret
VIKUNJA_SERVICE_ENABLEREGISTRATION=false
VIKUNJA_LOG_LEVEL=INFO

# File storage
VIKUNJA_FILES_TYPE=local
VIKUNJA_FILES_BASEPATH=/app/vikunja/files

# PostgreSQL container settings
POSTGRES_DB=vikunja
POSTGRES_USER=vikunja
POSTGRES_PASSWORD=change-me

# Vikunja database connection settings
# The app uses the POSTGRES_* values above for database name, user, and password.
VIKUNJA_DATABASE_TYPE=postgres
VIKUNJA_DATABASE_HOST=postgres:5432
VIKUNJA_DATABASE_SSLMODE=disable
VIKUNJA_DATABASE_MAXOPENCONNECTIONS=25
VIKUNJA_DATABASE_MAXIDLECONNECTIONS=25
VIKUNJA_DATABASE_MAXCONNECTIONLIFETIME=10000
